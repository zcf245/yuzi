generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ActivationKey {
  id        String   @id @default(uuid())
  key       String   @unique
  prefix    String?
  suffix    String?
  status    String   @default("inactive") // inactive, active, expired
  createdAt DateTime @default(now())
  expiresAt DateTime?
  usedAt    DateTime?
  deviceId  String?
  validDays Int      @default(30)
}

model ActivationRecord {
  id        String   @id @default(uuid())
  keyId     String
  deviceId  String
  activatedAt DateTime @default(now())
  expiresAt DateTime
  status    String   @default("active") // active, expired
}
